<script>
  function selectOdd(btn) {
    const row = btn.closest('.odds-row');
    row.querySelectorAll('.odd-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
  }

  function selectMarket(btn) {
    const group = btn.closest('.market-opts');
    group.querySelectorAll('.market-opt').forEach(b => {
      b.style.color = '';
      b.style.borderColor = '';
      b.style.background = '';
    });
    btn.style.color = 'var(--accent3)';
    btn.style.borderColor = 'var(--accent3)';
    btn.style.background = 'rgba(0,212,255,0.06)';
  }
</script>


